{
  "name": "chartcompare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "node -e \"console.log('No frontend tests configured yet')\"",
    "server:dev": "npm --prefix server run dev",
    "server:build": "npm --prefix server run build",
    "server:start": "npm --prefix server run start",
    "server:test": "npm --prefix server run test",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.{js,json}\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy:wasm": "mkdir -p public && cp node_modules/scichart/_wasm/scichart2d.wasm node_modules/scichart/_wasm/scichart2d-nosimd.wasm public/ 2>/dev/null || true",
    "generate:data": "node scripts/generateChartData.js",
    "postinstall": "patch-package && npm run copy:wasm"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@tanstack/react-query": "^5.90.21",
    "@types/leaflet-draw": "^1.0.13",
    "color-alpha": "^2.0.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "notistack": "^3.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "scichart": "^5.0.178",
    "scichart-react": "^1.0.0",
    "vite-plugin-static-copy": "^3.2.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wabt": "^1.0.36"
  }
}
